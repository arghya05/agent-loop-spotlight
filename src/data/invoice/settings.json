    "settlementApprovalThreshold": 10000,
    "writeOffApprovalThreshold": 5000
  },
  "cashOptimization": {
    "minSavingsThreshold": 500,
    "cashConstraintBand": "moderate",
    "preferredSuppliers": ["SUP-A1", "SUP-E5"]
  },
  "fraudRules": {
    "duplicateDetection": true,
    "blacklistedSuppliers": ["SUP-I9"],
    "autoHoldSanctioned": true
  }
}
